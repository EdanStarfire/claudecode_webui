#!/usr/bin/env bash
set -euo pipefail

# claude-docker: Run Claude Code in a disposable Docker container
#
# Usage:
#   claude-docker [claude-args...]
#
# Examples:
#   claude-docker -p "explain this codebase"
#   claude-docker -p "fix the bug in main.py" --allowedTools bash,edit
#   claude-docker                              # interactive mode
#
# The container:
#   - Mounts the current directory at its real host path inside the container
#   - Mounts ~/.claude credentials for subscription auth
#   - Is removed after exit (--rm)
#   - Runs as non-root user
#
# Environment variables:
#   CLAUDE_DOCKER_IMAGE         - Docker image name (default: claude-code:local)
#   CLAUDE_DOCKER_EXTRA_MOUNTS  - Comma-separated extra -v mount specs
#   CLAUDE_DOCKER_WORKSPACE     - Workspace directory to mount (default: $PWD)
#   CLAUDE_DOCKER_DATA_DIR      - Host dir for persistent Claude session data (enables --resume)
#   CLAUDE_DOCKER_HOME          - Home directory inside the container (default: /home/claude)
#   CLAUDE_DOCKER_MEMORY_LIMIT  - Container memory limit (default: none, e.g. "4g", "2048m")
#   CLAUDE_DOCKER_SHM_SIZE      - /dev/shm size for Chromium (default: 256m)
#
# Auto-forwarded from host environment (when available):
#   SSH_AUTH_SOCK               - SSH agent socket (mounted at /ssh-agent, env set inside container)

DEFAULT_IMAGE="claude-code:local"
IMAGE_NAME="${CLAUDE_DOCKER_IMAGE:-$DEFAULT_IMAGE}"
CONTAINER_NAME="claude-code-$$"
DOCKER_HOME="${CLAUDE_DOCKER_HOME:-/home/claude}"

# Issue #781: Configurable resource limits
MEMORY_LIMIT="${CLAUDE_DOCKER_MEMORY_LIMIT:-}"
SHM_SIZE="${CLAUDE_DOCKER_SHM_SIZE:-256m}"

# Issue #781: Log container identity for crash correlation
echo "[claude-docker] Container: $CONTAINER_NAME, Image: $IMAGE_NAME, PID: $$" >&2

# Build default image if it doesn't exist; fail fast for custom images
# Note: Do NOT wrap this with `timeout` — after a container crash, Docker may be
# briefly busy with --rm cleanup and a timeout can cause false "not found" errors.
if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
    if [ "$IMAGE_NAME" = "$DEFAULT_IMAGE" ]; then
        echo "Building Claude Code container image..."
        SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
        docker build -t "$IMAGE_NAME" "$SCRIPT_DIR"
    else
        echo "Error: Docker image '$IMAGE_NAME' not found. Build or pull it first." >&2
        exit 1
    fi
fi

# Determine workspace to mount (default: current directory)
WORKSPACE="${CLAUDE_DOCKER_WORKSPACE:-$(pwd)}"

# -i: always attach stdin (needed for piped input like stream-json)
# -t: only allocate TTY when stdin is a terminal (interactive mode)
DOCKER_FLAGS="-i"
if [ -t 0 ]; then
    DOCKER_FLAGS="-it"
fi

# Build extra mount flags from CLAUDE_DOCKER_EXTRA_MOUNTS
EXTRA_MOUNT_FLAGS=""
if [ -n "${CLAUDE_DOCKER_EXTRA_MOUNTS:-}" ]; then
    IFS=',' read -ra MOUNTS <<< "$CLAUDE_DOCKER_EXTRA_MOUNTS"
    for mount in "${MOUNTS[@]}"; do
        mount="$(echo "$mount" | xargs)"  # trim whitespace
        if [ -n "$mount" ]; then
            EXTRA_MOUNT_FLAGS="$EXTRA_MOUNT_FLAGS -v $mount"
        fi
    done
fi

# Build persistent data dir mounts for session-scoped state.
# When CLAUDE_DOCKER_DATA_DIR is set, subdirectories are mounted into
# the container's ~/.claude/ so that session data survives container restarts.
#
# Mounted paths:
#   projects/        - Per-project conversation history
#   todos/           - Task/todo list data per session (legacy)
#   tasks/           - Team task lists for multi-agent swarms
#   plans/           - Plan mode plan files
#   debug/           - Debug logs per session
#   shell-snapshots/ - Shell state snapshots (bash context persistence)
#   session-env/     - Per-session environment variables
#   downloads/       - Files downloaded during sessions
DATA_DIR_FLAGS=""
if [ -n "${CLAUDE_DOCKER_DATA_DIR:-}" ]; then
    SESSION_DIRS="projects todos tasks plans debug shell-snapshots session-env downloads"
    for dir in $SESSION_DIRS; do
        mkdir -p "$CLAUDE_DOCKER_DATA_DIR/$dir"
        DATA_DIR_FLAGS="$DATA_DIR_FLAGS -v $CLAUDE_DOCKER_DATA_DIR/$dir:$DOCKER_HOME/.claude/$dir"
    done
fi

# Forward CLAUDE_CODE_* environment variables into the container
# The SDK sets env vars like CLAUDE_CODE_ENABLE_TASKS, CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS
# which must be passed through to the Claude CLI inside the container
ENV_FLAGS=""
while IFS='=' read -r name value; do
    if [[ "$name" == CLAUDE_CODE_* ]]; then
        ENV_FLAGS="$ENV_FLAGS -e $name=$value"
    fi
done < <(env)

# Scan arguments for file-based flags that need host files mounted into container
# The SDK passes --append-system-prompt-file or --system-prompt-file with a temp file path
FILE_MOUNT_FLAGS=""
PREV_ARG=""
for arg in "$@"; do
    if [ "$PREV_ARG" = "--append-system-prompt-file" ] || [ "$PREV_ARG" = "--system-prompt-file" ]; then
        if [ -f "$arg" ]; then
            FILE_MOUNT_FLAGS="$FILE_MOUNT_FLAGS -v $arg:$arg:ro"
        fi
    fi
    PREV_ARG="$arg"
done

# Issue #794: Auto-forward SSH agent if available (enables git SSH operations inside container)
SSH_AGENT_FLAGS=""
if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
    SSH_AGENT_FLAGS="-v $SSH_AUTH_SOCK:/ssh-agent -e SSH_AUTH_SOCK=/ssh-agent"
fi

# Issue #781: Build resource limit flags
RESOURCE_FLAGS=""
if [ -n "$MEMORY_LIMIT" ]; then
    RESOURCE_FLAGS="$RESOURCE_FLAGS --memory=$MEMORY_LIMIT"
    echo "[claude-docker] Memory limit: $MEMORY_LIMIT" >&2
fi
# Always set --shm-size for Chromium stability (default 256m vs Docker's 64m default)
RESOURCE_FLAGS="$RESOURCE_FLAGS --shm-size=$SHM_SIZE"

# Run the container (capture exit code for diagnostics)
docker run \
    --rm \
    $DOCKER_FLAGS \
    --name "$CONTAINER_NAME" \
    -v "$WORKSPACE:$WORKSPACE" \
    -w "$WORKSPACE" \
    -v "$HOME/.claude/.credentials.json:$DOCKER_HOME/.claude/.credentials.json" \
    -v "$HOME/.claude/settings.json:$DOCKER_HOME/.claude/settings.json:ro" \
    -e "CLAUDE_CODE_DISABLE_AUTO_UPDATE=1" \
    $ENV_FLAGS \
    $DATA_DIR_FLAGS \
    $EXTRA_MOUNT_FLAGS \
    $FILE_MOUNT_FLAGS \
    $SSH_AGENT_FLAGS \
    $RESOURCE_FLAGS \
    "$IMAGE_NAME" \
    "$@"
EXIT_CODE=$?

# Issue #781: Log exit code for crash correlation
if [ $EXIT_CODE -ne 0 ]; then
    echo "[claude-docker] Container $CONTAINER_NAME exited with code $EXIT_CODE" >&2
    if [ $EXIT_CODE -eq 137 ]; then
        echo "[claude-docker] Container was killed (OOM or SIGKILL)" >&2
    elif [ $EXIT_CODE -eq 139 ]; then
        echo "[claude-docker] Container crashed (segmentation fault)" >&2
    fi
fi

exit $EXIT_CODE
